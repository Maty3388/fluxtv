<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <TextureView android:id="@+id/textureView"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

    <!-- Zonas táctiles para zapping en mobile -->
    <LinearLayout android:id="@+id/btnZapUp"
        android:layout_width="64dp" android:layout_height="64dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp" android:layout_marginBottom="40dp"
        android:gravity="center" android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="▲" android:textColor="#FFFFFF" android:textSize="22sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/btnZapDown"
        android:layout_width="64dp" android:layout_height="64dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp" android:layout_marginTop="40dp"
        android:gravity="center" android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="▼" android:textColor="#FFFFFF" android:textSize="22sp"/>
    </LinearLayout>

    <!-- Overlay de carga/zapping -->
    <LinearLayout android:id="@+id/layoutLoading"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#000000" android:orientation="vertical"
        android:gravity="center" android:visibility="gone">

        <ImageView android:id="@+id/ivLogo"
            android:layout_width="80dp" android:layout_height="80dp"
            android:scaleType="centerInside" android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvNumber"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#A855F7" android:textSize="80sp"
            android:textStyle="bold" android:lineSpacingExtra="-10dp"/>

        <TextView android:id="@+id/tvName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="22sp"
            android:textStyle="bold" android:layout_marginTop="8dp"/>

        <TextView android:id="@+id/tvCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#003344" android:textSize="14sp"
            android:layout_marginTop="4dp" android:layout_marginBottom="28dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="#A855F7" android:layout_margin="5dp"/>
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="#A855F7" android:layout_margin="5dp"/>
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="#A855F7" android:layout_margin="5dp"/>
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="#333333" android:layout_margin="5dp"/>
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="#333333" android:layout_margin="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Estado de error -->
    <LinearLayout android:id="@+id/layoutError"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#0A0E1A" android:orientation="vertical"
        android:gravity="center" android:padding="32dp" android:visibility="gone">

        <FrameLayout
            android:layout_width="56dp" android:layout_height="56dp"
            android:background="@drawable/bg_error_icon"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="!" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#F43F5E"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No se pudo cargar el canal" android:textColor="#FFFFFF"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>

        <TextView android:id="@+id/tvErrorChannel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#6B7A8F" android:textSize="13sp" android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btnRetryError"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:minWidth="160dp"
            android:text="REINTENTAR" android:textColor="#000000" android:textStyle="bold"
            android:backgroundTint="#00D4FF" android:focusable="true"/>
    </LinearLayout>

    <!-- Controles al presionar OK -->
    <!-- Overlay Estilo C: Banner inferior moderno -->
    <LinearLayout android:id="@+id/layoutControls"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom" android:background="@drawable/bg_player_controls"
        android:orientation="horizontal" android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="48dp" android:paddingBottom="18dp"
        android:gravity="flex_end|bottom" android:visibility="gone">

        <!-- Logo canal -->
        <FrameLayout
            android:layout_width="52dp" android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_player_logo"
            android:elevation="6dp">
            <ImageView android:id="@+id/ivControlLogo"
                android:layout_width="38dp" android:layout_height="38dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"/>
        </FrameLayout>

        <!-- Info central -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">

            <!-- Nombre + badge EN VIVO -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="3dp">
                <TextView android:id="@+id/tvControlName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="EN VIVO" android:textColor="#F5A623" android:textSize="9sp"
                    android:textStyle="bold" android:letterSpacing="0.05"
                    android:background="@drawable/bg_live_badge"
                    android:paddingHorizontal="6dp" android:paddingVertical="2dp"/>
            </LinearLayout>

            <!-- Programa EPG -->
            <TextView android:id="@+id/tvControlCategory"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#8A95B0" android:textSize="11sp"
                android:maxLines="1" android:ellipsize="end"
                android:layout_marginBottom="8dp"/>

            <!-- Barra de progreso decorativa -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="3dp"
                android:background="#1AFFFFFF">
                <View android:layout_width="45%" android:layout_height="match_parent"
                    android:background="@drawable/bg_epg_progress"/>
            </FrameLayout>

        </LinearLayout>

        <!-- Número de canal grande -->
        <TextView android:id="@+id/tvControlNumber"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#26FFFFFF" android:textSize="36sp" android:textStyle="bold"
            android:fontFamily="monospace" android:layout_marginStart="12dp"/>

    </LinearLayout>

    <!-- Controles VOD -->
    <LinearLayout android:id="@+id/layoutVodControls"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="8dp">
            <ImageButton android:id="@+id/btnRewind"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_refresh"
                android:tint="#FFFFFF" android:background="@android:color/transparent"
                android:contentDescription="Rewind"/>
            <ImageButton android:id="@+id/btnPrev"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_home"
                android:tint="#FFFFFF" android:background="@android:color/transparent"
                android:layout_marginHorizontal="8dp"
                android:contentDescription="Anterior"/>
            <ImageButton android:id="@+id/btnPlayPause"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#00E5FF" android:background="@android:color/transparent"
                android:layout_marginHorizontal="8dp"
                android:contentDescription="Play/Pause"/>
            <ImageButton android:id="@+id/btnNext"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_star"
                android:tint="#FFFFFF" android:background="@android:color/transparent"
                android:layout_marginHorizontal="8dp"
                android:contentDescription="Siguiente"/>
            <ImageButton android:id="@+id/btnForward"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_refresh"
                android:tint="#FFFFFF" android:background="@android:color/transparent"
                android:contentDescription="Forward"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvPosition"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:text="00:00" android:fontFamily="monospace"
                android:layout_marginEnd="8dp"/>
            <SeekBar android:id="@+id/seekBar"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#00E5FF"
                android:thumbTint="#00E5FF"/>
            <TextView android:id="@+id/tvDuration"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#888888" android:textSize="12sp"
                android:text="00:00" android:fontFamily="monospace"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
