<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050810">

    <!-- Glow superior cyan -->
    <View
        android:layout_width="300dp" android:layout_height="300dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-100dp"
        android:background="@drawable/bg_login_glow_top"/>

    <!-- Glow inferior ámbar -->
    <View
        android:layout_width="250dp" android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-50dp" android:layout_marginBottom="-80dp"
        android:background="@drawable/bg_login_glow_bottom"/>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center_horizontal"
            android:paddingTop="72dp" android:paddingBottom="32dp"
            android:paddingHorizontal="32dp">

            <!-- Logo F con glow -->
            <TextView
                android:layout_width="64dp" android:layout_height="64dp"
                android:text="F" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:gravity="center"
                android:background="@drawable/bg_login_logo"
                android:layout_marginBottom="20dp"
                android:elevation="8dp"/>

            <!-- Título FLUX TV -->
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FLUX" android:textColor="#FFFFFF"
                    android:textSize="26sp" android:textStyle="bold" android:letterSpacing="0.05"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TV" android:textColor="#F5A623"
                    android:textSize="26sp" android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tu universo de entretenimiento" android:textColor="#6B7A8F"
                android:textSize="12sp" android:layout_marginBottom="36dp"/>

            <!-- Formulario -->
            <EditText android:id="@+id/etEmail"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:hint="Correo electrónico" android:textColor="#FFFFFF"
                android:textColorHint="#4A5568" android:textSize="14sp"
                android:background="@drawable/bg_login_field" android:paddingHorizontal="16dp"
                android:inputType="textEmailAddress" android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/etPassword"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:hint="Contraseña" android:textColor="#FFFFFF"
                android:textColorHint="#4A5568" android:textSize="14sp"
                android:background="@drawable/bg_login_field" android:paddingHorizontal="16dp"
                android:inputType="textPassword" android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tvError"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#F43F5E" android:textSize="12sp"
                android:layout_marginBottom="12dp" android:visibility="gone"/>

            <Button android:id="@+id/btnLogin"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="INGRESAR" android:textColor="#000000"
                android:textStyle="bold" android:background="@drawable/bg_login_btn"
                android:stateListAnimator="@null" android:elevation="6dp"/>

            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_gravity="center" android:layout_marginTop="16dp"
                android:visibility="gone" android:indeterminateTint="#00D4FF"/>
        </LinearLayout>
    </ScrollView>
</FrameLayout>

