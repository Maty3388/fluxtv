<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="horizontal">

    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Z" android:textColor="@color/primary"
            android:textSize="96sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FLUX TV" android:textColor="@color/text_primary"
            android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tu universo de entretenimiento" android:textColor="@color/text_hint"
            android:textSize="14sp" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="match_parent"
        android:background="@color/border"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:gravity="center" android:orientation="vertical"
        android:padding="48dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Iniciar sesión" android:textColor="@color/text_primary"
            android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>

        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="Correo electrónico" android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" android:textSize="16sp"
            android:background="@color/surface" android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress" android:layout_marginBottom="16dp"/>

        <EditText android:id="@+id/etPassword"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="Contraseña" android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" android:textSize="16sp"
            android:background="@color/surface" android:paddingHorizontal="16dp"
            android:inputType="textPassword" android:layout_marginBottom="24dp"/>

        <TextView android:id="@+id/tvError"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/error" android:textSize="13sp"
            android:layout_marginBottom="16dp" android:visibility="gone"/>

        <Button android:id="@+id/btnLogin"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="INGRESAR" android:textColor="@color/background"
            android:textStyle="bold" android:backgroundTint="@color/primary"
            android:focusable="true"/>

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginTop="16dp" android:visibility="gone"
            android:indeterminateTint="@color/primary"/>
    </LinearLayout>
</LinearLayout>
