<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">

    <!-- Hero banner -->
    <FrameLayout android:id="@+id/heroBanner"
        android:layout_width="match_parent" android:layout_height="90dp"
        android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp"
        android:visibility="gone"/>

    <!-- Scroll de categorías con filas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:nextFocusLeft="@id/btnTv"
        android:nextFocusUp="@id/heroBanner"
        android:descendantFocusability="afterDescendants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:overScrollMode="never"/>

</LinearLayout>
