<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#CC000000" android:gravity="center">

    <LinearLayout android:layout_width="400dp" android:layout_height="wrap_content"
        android:background="@color/surface" android:orientation="vertical"
        android:padding="32dp">

        <TextView android:id="@+id/tvAvatar"
            android:layout_width="72dp" android:layout_height="72dp"
            android:text="👤" android:textSize="36sp"
            android:gravity="center" android:layout_gravity="center"
            android:background="@color/surface2"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvEmail"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="16sp"
            android:textStyle="bold" android:layout_gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Correo electrónico" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvSubEnd"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="16sp"
            android:textStyle="bold" android:layout_gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Fecha de vencimiento" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="16dp"/>

        <Button android:id="@+id/btnPin"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🔒 Configurar PIN Parental" android:textColor="@color/primary"
            android:backgroundTint="@color/surface2" android:layout_marginBottom="8dp"
            android:focusable="true"/>

        <Button android:id="@+id/btnClose"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Cerrar" android:textColor="@color/text_primary"
            android:backgroundTint="@color/surface2" android:layout_marginBottom="8dp"
            android:focusable="true"/>

        <Button android:id="@+id/btnLogout"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Cerrar Sesión" android:textColor="@color/error"
            android:backgroundTint="@color/surface" android:focusable="true"/>
    </LinearLayout>
</LinearLayout>
