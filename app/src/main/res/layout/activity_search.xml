<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔍 " android:textSize="20sp"/>
        <EditText android:id="@+id/etSearch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:hint="Buscar canal..."
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:textSize="18sp" android:background="@color/surface"
            android:paddingHorizontal="16dp" android:imeOptions="actionSearch"
            android:singleLine="true" android:focusable="true"/>
        <Button android:id="@+id/btnBack"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:text="✕" android:textColor="@color/text_secondary"
            android:backgroundTint="@color/surface" android:layout_marginStart="8dp"
            android:focusable="true"/>
    </LinearLayout>

    <TextView android:id="@+id/tvResults"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvResults"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:focusable="true"/>
</LinearLayout>
