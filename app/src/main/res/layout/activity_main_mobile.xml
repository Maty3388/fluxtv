<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">

    <!-- Header top -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/surface" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:orientation="horizontal">
        <ImageView android:id="@+id/ivLogo"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:id="@+id/tvUserEmail"
                android:textColor="@color/text_secondary" android:textSize="11sp"/>
            <TextView android:id="@+id/tvVencimiento"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/primary" android:textSize="11sp" android:textStyle="bold"/>
        </LinearLayout>
        <ImageView android:id="@+id/btnBuscar"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_search" android:tint="@color/text_secondary"
            android:padding="6dp" android:layout_marginEnd="8dp"/>
        <ImageView android:id="@+id/btnRefresh"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_refresh" android:tint="@color/text_secondary"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- Tabs horizontales -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="44dp"
        android:background="@color/surface" android:scrollbars="none"
        android:paddingHorizontal="8dp">
        <LinearLayout android:id="@+id/tabsContainer"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border"/>

    <!-- Chips de categorías -->
    <HorizontalScrollView android:id="@+id/categoriesScroll"
        android:layout_width="match_parent" android:layout_height="40dp"
        android:scrollbars="none" android:paddingHorizontal="8dp"
        android:background="@color/background" android:visibility="visible">
        <LinearLayout android:id="@+id/categoriesContainer"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Contenido principal -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <FrameLayout android:id="@+id/mainContainer"
            android:layout_width="match_parent" android:layout_height="match_parent"/>
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="visible">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:padding="16dp">
                <View android:layout_width="200dp" android:layout_height="20dp"
                    android:layout_marginBottom="16dp" android:background="#1AFFFFFF"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:background="#1AFFFFFF"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:background="#1AFFFFFF"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_weight="1" android:background="#1AFFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>
    </FrameLayout>

    <!-- Bottom Navigation -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:background="@color/surface" android:orientation="horizontal"
        android:elevation="8dp">
        <LinearLayout android:id="@+id/navInicio"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_home" android:tint="@color/primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Inicio" android:textColor="@color/primary" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navMisListas"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_star" android:tint="@color/text_secondary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mis listas" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navExplorar"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_explore" android:tint="@color/text_secondary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Explorar" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navCuenta"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_settings" android:tint="@color/text_secondary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cuenta" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
