<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical"
    android:gravity="center">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Seleccioná tu Perfil" android:textColor="@color/text_primary"
        android:textSize="28sp" android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="¿Quién está mirando?" android:textColor="@color/text_secondary"
        android:textSize="14sp" android:layout_marginBottom="48dp"/>

    <LinearLayout android:id="@+id/profilesContainer"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"/>

</LinearLayout>
