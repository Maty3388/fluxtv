<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="horizontal">

    <!-- Sidebar minimalista con iconos -->
    <LinearLayout android:id="@+id/sidebar"
        android:layout_width="64dp" android:layout_height="match_parent"
        android:background="@color/surface" android:orientation="vertical"
        android:gravity="center_horizontal" android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Logo F -->
        <TextView android:layout_width="44dp" android:layout_height="44dp"
            android:text="F" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/background" android:gravity="center"
            android:layout_marginBottom="16dp"
            android:background="@drawable/logo_circle_bg"/>

        <!-- Botones icono -->
        <LinearLayout android:id="@+id/btnMiCuenta"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnTv"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_tv" android:tint="@color/primary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnPeliculas"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_movie" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnSeries"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_star" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnBuscar"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_search" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnFavoritos"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_star" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnAdultos"
            android:nextFocusRight="@+id/rvCategories"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_lock" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout android:id="@+id/btnClearCache"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector"
            android:layout_marginBottom="4dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_refresh" android:tint="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnLogout"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:focusable="true"
            android:background="@drawable/sidebar_icon_selector">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_logout" android:tint="@color/error"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Borde cyan -->
    <View android:layout_width="2dp" android:layout_height="match_parent"
        android:background="@color/primary"/>

    <!-- Contenido principal -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/surface" android:gravity="center_vertical"
            android:paddingHorizontal="20dp" android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FLUX" android:textColor="@color/primary"
                android:textSize="18sp" android:textStyle="bold" android:letterSpacing="0.1"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TV" android:textColor="#FFA500"
                android:textSize="18sp" android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1"/>
            <TextView android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="10sp"
                android:layout_marginEnd="16dp"/>
            <TextView android:id="@+id/tvVencimiento"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/primary" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Fragment canales -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <FrameLayout android:id="@+id/mainContainer"
                android:layout_width="match_parent" android:layout_height="match_parent"/>
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerLayout"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:visibility="visible">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="16dp">
                    <View android:layout_width="200dp" android:layout_height="20dp"
                        android:layout_marginBottom="16dp" android:background="#1AFFFFFF"/>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <View android:layout_width="160dp" android:layout_height="115dp"
                            android:layout_marginEnd="8dp" android:background="#1AFFFFFF"/>
                        <View android:layout_width="160dp" android:layout_height="115dp"
                            android:layout_marginEnd="8dp" android:background="#1AFFFFFF"/>
                        <View android:layout_width="160dp" android:layout_height="115dp"
                            android:background="#1AFFFFFF"/>
                    </LinearLayout>
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
