<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:focusable="true" android:focusableInTouchMode="true"
    android:background="@drawable/sidebar_item_selector"
    android:gravity="center_vertical">

    <TextView android:id="@+id/tvEpNum"
        android:layout_width="48dp" android:layout_height="wrap_content"
        android:textColor="@color/primary" android:textSize="14sp"
        android:textStyle="bold" android:gravity="center"/>

    <TextView android:id="@+id/tvEpTitle"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/text_primary"
        android:textSize="13sp" android:layout_marginStart="8dp"/>
</LinearLayout>
