<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical" android:padding="48dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ajustes" android:textColor="@color/primary"
        android:textSize="28sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>
    <TextView android:id="@+id/tvAppVersion"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_secondary" android:textSize="16sp"
        android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnLogout"
        android:layout_width="200dp" android:layout_height="52dp"
        android:text="Cerrar sesión" android:textColor="@color/text_primary"
        android:backgroundTint="@color/surface2" android:focusable="true"/>
</LinearLayout>
