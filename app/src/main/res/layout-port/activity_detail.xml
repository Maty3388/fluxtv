<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">

    <ImageView android:id="@+id/ivBackdrop"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="centerCrop" android:alpha="0.35"/>

    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/detail_gradient"/>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <ImageView android:id="@+id/ivPoster"
                android:layout_width="160dp" android:layout_height="240dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="centerCrop" android:background="@color/surface2"/>

            <TextView android:id="@+id/tvTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:textSize="22sp"
                android:textStyle="bold" android:maxLines="3"
                android:gravity="center"
                android:layout_marginTop="16dp"/>

            <TextView android:id="@+id/tvMeta"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/primary" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginTop="6dp"
                android:gravity="center"/>

            <TextView android:id="@+id/tvDescription"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"/>

            <Button android:id="@+id/btnPlay"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="▶ REPRODUCIR" android:textColor="@color/background"
                android:backgroundTint="@color/primary" android:textStyle="bold"
                android:layout_marginTop="20dp" android:focusable="true"/>

            <Button android:id="@+id/btnBack"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="← Volver" android:textColor="@color/text_secondary"
                android:backgroundTint="@color/surface2"
                android:layout_marginTop="8dp" android:focusable="true"/>

            <!-- Lista de episodios (solo series) -->
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvEpisodes"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>

